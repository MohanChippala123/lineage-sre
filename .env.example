# --- Agent backend (pick one; auto-detected in this order) --------------------
# 1. Gemini free tier — no cost, no card. Key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# 2. Anthropic API
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5

# 3. No key at all: if you're logged in to Claude Code, the Claude Agent SDK
#    backend runs on your subscription automatically.

# --- DataHub -------------------------------------------------------------------
# Local quickstart (requires Docker):
DATAHUB_GMS_URL=http://localhost:8080
# DATAHUB_TOKEN=

# DataHub Cloud free trial (no Docker needed) — https://datahub.com/free-trial/
# DATAHUB_GMS_URL=https://<yourorg>.acryl.io/gms
# DATAHUB_TOKEN=<personal access token from Settings -> Access Tokens>

# --- Misc ---------------------------------------------------------------------
# LINEAGE_SRE_WAREHOUSE=demo_warehouse.duckdb
