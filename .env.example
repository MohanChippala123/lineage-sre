# Required: Anthropic API key for the agent
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model override (defaults to claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5

# DataHub GMS endpoint (default matches `datahub docker quickstart`)
DATAHUB_GMS_URL=http://localhost:8080

# Optional: DataHub personal access token (not needed for local quickstart)
# DATAHUB_TOKEN=

# Optional: path to the demo DuckDB warehouse file
# LINEAGE_SRE_WAREHOUSE=demo_warehouse.duckdb
